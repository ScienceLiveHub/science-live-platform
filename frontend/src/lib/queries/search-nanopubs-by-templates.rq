# Full-text search on nanopub labels or all literal fields, filtered by template.
# Excludes example, templates, invalidated, and superseded.
# Only returns nanopubs created from one of the provided templates.
#
# Placeholder: `?_searchTerm` - the user's search string.
# Placeholder: `?_searchProperty` - RAW: the search property to match against.
#   Use "rdfs:label" for label-only search or "npa:hasFilterLiteral" for full-text search.
# Placeholder: `?_templateValues` - RAW: a SPARQL VALUES block, e.g.
#   "(<https://w3id.org/np/RA...current>) (<https://w3id.org/np/RA...legacy>)"
# Placeholder: `?_limit` - RAW: maximum number of results to return (e.g. 10).
# Placeholder: `?_offset` - RAW: number of results to skip for pagination (e.g. 0).
# Placeholder: `?_sortBy` - RAW: ORDER BY clause (e.g. "desc(?maxScore)" or "desc(?date)").

prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix np: <http://www.nanopub.org/nschema#>
prefix npa: <http://purl.org/nanopub/admin/>
prefix npx: <http://purl.org/nanopub/x/>
prefix dct: <http://purl.org/dc/terms/>
prefix search: <http://www.openrdf.org/contrib/lucenesail#>
prefix nt: <https://w3id.org/np/o/ntemplate/>

select ?np ?label ?date ?creator ?type ?template (count(?refNp) as ?referenceCount) (max(?score) as ?maxScore) where {
  values (?template) { ?_templateValues }
  graph npa:graph {
    ?np npa:hasValidSignatureForPublicKeyHash ?pubkey .
    filter not exists { ?npx npx:invalidates ?np ; npa:hasValidSignatureForPublicKeyHash ?pubkey . }

    # Exclude examples
    filter not exists { ?np npx:hasNanopubType npx:ExampleNanopub }

    # Exclude templates
    filter not exists { ?np npx:hasNanopubType nt:AssertionTemplate }
    filter not exists { ?np npx:hasNanopubType nt:ProvenanceTemplate }
    filter not exists { ?np npx:hasNanopubType nt:PubinfoTemplate }

    optional { ?np rdfs:label ?label . }
    ?np dct:created ?date ;
        npx:hasNanopubType ?type;
        dct:creator ?creator .
  }
  graph npa:networkGraph { ?np nt:wasCreatedFromTemplate ?template . }

  ?np search:matches [
    search:query ?_searchTerm ;
    search:property ?_searchProperty ;
    search:score ?score ] .

  # Count references from other nanopubs using npa:networkGraph
  optional { graph npa:networkGraph { ?refNp npa:refersToNanopub ?np . } }

} group by ?np ?label ?date ?creator ?type ?template order by ?_sortBy limit ?_limit offset ?_offset
