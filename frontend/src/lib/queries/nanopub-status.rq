# Get status attributes for a nanopublication.
# Returns the latest supersedes, latest retracts, approvals count, and disapprovals count.
#
# Placeholder: `?_nanopubUri` - URI: the URI of the nanopub.

prefix np: <http://www.nanopub.org/nschema#>
prefix npa: <http://purl.org/nanopub/admin/>
prefix npx: <http://purl.org/nanopub/x/>
prefix dct: <http://purl.org/dc/terms/>

select ?supercededBy ?retractedBy ?approvals ?disapprovals
where {
  # Approval count - always returns one row
  {
    select (count(distinct ?approvalNp) as ?approvals) where {
      graph npa:graph {
        ?approvalNp npa:hasValidSignatureForPublicKey ?pubkey .
      }
      ?approvalNp np:hasAssertion ?assertion .
      graph ?assertion {
        ?approvalNp npx:approvesOf ?_nanopubUri .
      }
    }
  }

  # Disapproval count - always returns one row
  {
    select (count(distinct ?disapprovalNp) as ?disapprovals) where {
      graph npa:graph {
        ?disapprovalNp npa:hasValidSignatureForPublicKey ?pubkey .
      }
      ?disapprovalNp np:hasAssertion ?assertion .
      graph ?assertion {
        ?disapprovalNp npx:disapprovesOf ?_nanopubUri .
      }
    }
  }

  # Optional: Latest superseding nanopub (from pubinfo graph)
  # npx:supersedes is checked in the pubinfo graph
  optional {
    graph npa:graph {
      ?supercededBy npa:hasValidSignatureForPublicKey ?supersedePubkey .
      ?supercededBy dct:created ?supersedeDate .
    }
    ?supercededBy np:hasPubinfo ?pubinfo .
    graph ?pubinfo {
      ?supercededBy npx:supersedes ?_nanopubUri .
    }
    # Keep only the latest by filtering out any that have a newer one
    filter not exists {
      graph npa:graph {
        ?newerSupersede npa:hasValidSignatureForPublicKey ?newerSupersedePubkey .
        ?newerSupersede dct:created ?newerSupersedeDate .
      }
      ?newerSupersede np:hasPubinfo ?newerPubinfo .
      graph ?newerPubinfo {
        ?newerSupersede npx:supersedes ?_nanopubUri .
      }
      filter(?newerSupersedeDate > ?supersedeDate)
    }
  }

  # Optional: Latest retracting nanopub (from assertion graph)
  # npx:retracts is checked in the assertion graph
  optional {
    graph npa:graph {
      ?retractedBy npa:hasValidSignatureForPublicKey ?retractPubkey .
      ?retractedBy dct:created ?retractDate .
    }
    ?retractedBy np:hasAssertion ?retractAssertion .
    graph ?retractAssertion {
      ?retractedBy npx:retracts ?_nanopubUri .
    }
    # Keep only the latest by filtering out any that have a newer one
    filter not exists {
      graph npa:graph {
        ?newerRetract npa:hasValidSignatureForPublicKey ?newerRetractPubkey .
        ?newerRetract dct:created ?newerRetractDate .
      }
      ?newerRetract np:hasAssertion ?newerRetractAssertion .
      graph ?newerRetractAssertion {
        ?newerRetract npx:retracts ?_nanopubUri .
      }
      filter(?newerRetractDate > ?retractDate)
    }
  }
}