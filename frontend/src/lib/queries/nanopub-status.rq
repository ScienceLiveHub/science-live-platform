# Get status attributes for a nanopublication.
# Returns the latest supersedes, latest retracts, approvals count, disapprovals count, and comments count.
#
# Placeholder: `?_nanopubUri` - URI: the URI of the nanopub.

prefix np: <http://www.nanopub.org/nschema#>
prefix npa: <http://purl.org/nanopub/admin/>
prefix npx: <http://purl.org/nanopub/x/>
prefix dct: <http://purl.org/dc/terms/>
prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>

select ?supercededBy ?retractedBy ?approvals ?disapprovals ?comments
where {
  # Approval count - always returns one row
  {
    select (count(distinct ?approvalNp) as ?approvals) where {
      graph npa:graph {
        ?approvalNp npa:hasValidSignatureForPublicKeyHash ?pubkey .
        filter not exists { ?npx npx:invalidates ?approvalNp ; npa:hasValidSignatureForPublicKeyHash ?pubkey . }
        ?approvalNp np:hasAssertion ?assertion .
      }
      graph ?assertion {
        ?approvalCreator npx:approvesOf ?_nanopubUri .
      }
    }
  }

  # Disapproval count - always returns one row
  {
    select (count(distinct ?disapprovalNp) as ?disapprovals) where {
      graph npa:graph {
        ?disapprovalNp npa:hasValidSignatureForPublicKeyHash ?pubkey .
        filter not exists { ?npx npx:invalidates ?disapprovalNp ; npa:hasValidSignatureForPublicKeyHash ?pubkey . }
        ?disapprovalNp np:hasAssertion ?assertion .
      }
      graph ?assertion {
        ?disapprovalCreator npx:disapprovesOf ?_nanopubUri .
      }
    }
  }

  # Comments count - always returns one row
  # A comment nanopub has rdfs:comment as predicate with the nanopubUri as object
  {
    select (count(distinct ?commentNp) as ?comments) where {
      graph npa:graph {
        ?commentNp npa:hasValidSignatureForPublicKeyHash ?commentPubkey .
        filter not exists { ?npx npx:invalidates ?commentNp ; npa:hasValidSignatureForPublicKeyHash ?pubkey . }
        ?commentNp np:hasAssertion ?commentAssertion .
      }
      graph ?commentAssertion {
        ?_nanopubUri rdfs:comment ?_s .
      }
    }
  }

  # Optional: Latest superseding nanopub
  # npx:supersedes is stored in npa:graph (admin graph)
  optional {
    graph npa:graph {
      ?supercededBy npa:hasValidSignatureForPublicKeyHash ?supersedePubkey .
      ?supercededBy dct:created ?supersedeDate .
      ?supercededBy npx:supersedes ?_nanopubUri .
    }
    # Keep only the latest by filtering out any that have a newer one
    filter not exists {
      graph npa:graph {
        ?newerSupersede npa:hasValidSignatureForPublicKeyHash ?newerSupersedePubkey .
        ?newerSupersede dct:created ?newerSupersedeDate .
        ?newerSupersede npx:supersedes ?_nanopubUri .
        filter(?newerSupersedeDate > ?supersedeDate)
      }
    }
  }

  # Optional: Latest retracting/invalidating nanopub
  # npx:invalidates is stored in npa:graph (admin graph)
  optional {
    graph npa:graph {
      ?retractedBy npa:hasValidSignatureForPublicKeyHash ?retractPubkey .
      ?retractedBy dct:created ?retractDate .
      ?retractedBy npx:invalidates ?_nanopubUri .
    }
    # Keep only the latest by filtering out any that have a newer one
    filter not exists {
      graph npa:graph {
        ?newerRetract npa:hasValidSignatureForPublicKeyHash ?newerRetractPubkey .
        ?newerRetract dct:created ?newerRetractDate .
        ?newerRetract npx:invalidates ?_nanopubUri .
        filter(?newerRetractDate > ?retractDate)
      }
    }
  }
}