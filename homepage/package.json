{
  "name": "homepage",
  "version": "1.0.0",
  "private": true,
  "description": "Science Live Homepage - Gatsby static site",
  "author": "vijay-prema",
  "keywords": [
    "gatsby"
  ],
  "scripts": {
    "develop": "gatsby develop",
    "start": "gatsby develop",
    "build": "gatsby build",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "typecheck": "tsc --noEmit",
    "deploy": "GATSBY_PLATFORM_URL=https://platform.sciencelive4all.org/ gatsby build && wrangler deploy",
    "deploy-dev": "GATSBY_PLATFORM_URL=https://platform-dev.sciencelive4all.org/ gatsby build && wrangler deploy -c wrangler-dev.jsonc"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gatsby": "^5.16.1",
    "gatsby-plugin-postcss": "^6.16.0",
    "lucide-react": "^1.8.0",
    "postcss": "^8.5.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.2",
    "wrangler": "^4.82.2"
  }
}
