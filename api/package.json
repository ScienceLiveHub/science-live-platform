{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev-bun": "bun --hot run src/index.ts",
    "check": "wrangler deploy --dry-run",
    "build": "wrangler build",
    "deploy": "wrangler deploy",
    "deploy-dev": "wrangler deploy -c wrangler-dev.jsonc",
    "cf-typegen": "wrangler types --include-runtime false",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "db:studio": "npx drizzle-kit studio --port=3002",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.2",
    "@daveyplate/better-auth-ui": "~3.4.0",
    "better-auth": "~1.6.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "postgres": "^3.4.9",
    "resend": "^6.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "~9.39.4",
    "@hono/vite-dev-server": "^0.25.1",
    "@types/node": "^25.6.0",
    "bun": "^1.3.12",
    "drizzle-kit": "^0.31.10",
    "eslint": "~9.39.4",
    "globals": "^17.5.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "wrangler": "^4.82.2"
  }
}
